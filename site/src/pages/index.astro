---
const name = "Sid Lakkoju";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{name}</title>
		<meta name="description" content="Sid Lakkoju — engineer at SpaceX. Personal site, projects, and links." />
		<meta name="author" content={name} />
		<link rel="canonical" href="https://sidlakkoju.github.io/" />

		<meta property="og:title" content={name} />
		<meta property="og:description" content="Engineer at SpaceX. Projects and writing." />
		<meta property="og:url" content="https://sidlakkoju.github.io/" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={name} />
		<meta name="twitter:description" content="Engineer at SpaceX. Projects and writing." />

		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Sid Lakkoju",
			"url": "https://sidlakkoju.github.io",
			"sameAs": [
				"https://github.com/sidlakkoju",
				"https://www.linkedin.com/in/sidlakkoju/",
				"https://www.youtube.com/@SidLakkoju"
			],
			"jobTitle": "Engineer",
			"worksFor": { "@type": "Organization", "name": "SpaceX" }
		})} />
	</head>
	<body>
		<canvas id="glcanvas" tabindex="1"></canvas>

		<main>
			<h1>{name}</h1>
			<p>Nerd @SpaceX 🚀</p>

			<nav class="social-links" aria-label="Social links">
				<a href="https://www.youtube.com/@SidLakkoju" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
						<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
					</svg>
				</a>
				<a href="https://github.com/sidlakkoju" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
						<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
					</svg>
				</a>
				<a href="https://www.linkedin.com/in/sidlakkoju/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
						<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
					</svg>
				</a>
			</nav>
		</main>

		<!-- Transparent overlay exactly covering the Rust-drawn pause button
		     (BTN_MARGIN=16px, BTN_SIZE=48px). Sits above canvas so JS learns
		     about pause clicks and can show/hide the info banner. -->
		<button id="pause-overlay" aria-label="Toggle simulation pause"></button>

		<!-- Info banner, hidden until sim is paused. -->
		<aside id="sim-info" aria-live="polite">
			<span>ⓘ</span>
			<p>
				The <strong>three-body problem</strong> has no general closed-form solution -
				even tiny differences in starting conditions lead to wildly different orbits.
				<br /><br />
				Fg = G * (m1 * m2) / d^2
				<br /><br />
				i think this is super cool - you should watch the netflix show.
			</p>
		</aside>

		<script is:inline src="/sim/mq_js_bundle.js"></script>
		<script is:inline>
			// macroquad's shim exposes `load(path)` once mq_js_bundle.js has run.
			// Honor prefers-reduced-motion by skipping the sim entirely.
			const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
			if (!reduce) {
				load("/sim/gravity_simulation.wasm");
			} else {
				document.getElementById("glcanvas").style.display = "none";
			}

			// Pause overlay: intercepts clicks above the canvas-drawn pause button.
			// Calls into wasm (window.wasm_exports is set by mq_js_bundle.js after
			// instantiation) and toggles the info banner.
			const pauseOverlay = document.getElementById("pause-overlay");
			const simInfo = document.getElementById("sim-info");
			let simPaused = false;

			pauseOverlay.addEventListener("click", () => {
				simPaused = !simPaused;
				window.wasm_exports?.set_paused(simPaused ? 1 : 0);
				simInfo.classList.toggle("visible", simPaused);
			});
		</script>

		<style is:global>
			html, body {
				margin: 0;
				padding: 0;
				height: 100%;
				background: #000;
				color: #fff;
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
				overflow: hidden;
			}

			#glcanvas {
				position: fixed;
				inset: 0;
				width: 100vw;
				height: 100vh;
				display: block;
				z-index: 0;
				/* Canvas catches clicks so the macroquad sim can handle its
				   own UI (pause button, drag handles). `main` below has
				   pointer-events: none so the overlaid text doesn't block. */
				pointer-events: auto;
				/* Disable native touch gestures so drag interactions aren't
				   hijacked by the browser's scroll/pinch on mobile. */
				touch-action: none;
			}

			main {
				position: relative;
				z-index: 1;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				pointer-events: none;
			}

			h1 {
				margin: 0;
				font-size: clamp(2.5rem, 8vw, 6rem);
				font-weight: 600;
				letter-spacing: -0.02em;
				mix-blend-mode: difference;
			}

			p {
				margin: 0.5rem 0 0;
				font-size: clamp(0.9rem, 2vw, 1.1rem);
				opacity: 0.7;
				mix-blend-mode: difference;
			}

			.social-links {
				display: flex;
				justify-content: center;
				gap: 2rem;
				margin-top: 1.5rem;
			}

			.social-links a {
				display: flex;
				color: #fff;
				opacity: 0.8;
				transition: transform 0.2s ease, opacity 0.2s ease;
				/* Re-enable clicks; parent <main> sets pointer-events: none
				   so canvas drags can pass through to the sim. */
				pointer-events: auto;
			}

			.social-links a:hover {
				transform: scale(1.25);
				opacity: 1;
			}

			.social-links svg {
				width: 2rem;
				height: 2rem;
			}

			/* Transparent overlay button, sits above canvas (z-index 2) at the
			   exact position of the Rust-drawn pause button. */
			#pause-overlay {
				position: fixed;
				top: 16px;
				right: 16px;
				width: 48px;
				height: 48px;
				background: transparent;
				border: none;
				cursor: pointer;
				z-index: 2;
				padding: 0;
			}

			/* Floating info island: hidden by default, fades + rises into view. */
			#sim-info {
				position: fixed;
				bottom: 2rem;
				left: 50%;
				transform: translateX(-50%) translateY(1.5rem);
				width: min(520px, calc(100vw - 3rem));
				display: flex;
				align-items: flex-start;
				gap: 0.75rem;
				padding: 1.1rem 1.4rem;
				background: rgba(10, 10, 10, 0.82);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border: 1px solid rgba(255, 255, 255, 0.12);
				border-radius: 16px;
				color: #fff;
				font-size: clamp(0.8rem, 1.5vw, 0.9rem);
				line-height: 1.6;
				opacity: 0;
				transition: opacity 0.25s ease, transform 0.25s ease;
				pointer-events: none;
				z-index: 1;
			}
			#sim-info.visible {
				opacity: 1;
				transform: translateX(-50%) translateY(0);
				pointer-events: auto;
			}
			#sim-info span {
				font-size: 1.1rem;
				flex-shrink: 0;
				margin-top: 0.05rem;
			}
			#sim-info p {
				margin: 0;
				opacity: 0.9;
			}
		</style>
	</body>
</html>
